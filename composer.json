{
    "name": "meu-projeto/app",
    "description": "Um projeto baseado no MVC-Base esqueleto.",
    "type": "project",
    "readme": "README.md",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Core\\": "core/"
        },
        "files": [
            "core/Support/helpers.php"
        ]
    },
    "authors": [
        {
            "name": "Felipe",
            "email": "felipe2006.co@gmail.com"
        }
    ],
    "keywords": [
        "php",
        "mvc",
        "skeleton",
        "framework",
        "router"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.0",
        "vlucas/phpdotenv": "^5.6",
        "twig/twig": "^3.23",
        "predis/predis": "^3.4",
        "firebase/php-jwt": "^7.0",
        "phpmailer/phpmailer": "^7.0"
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public"
    },
    "config": {
        "process-timeout": 0
    }
}